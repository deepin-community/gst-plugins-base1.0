From: Jaehoon Lee <jaehoon85.lee@lge.com>
Date: Wed, 19 Nov 2025 13:51:27 +0900
Subject: glbasesrc: Add unlock handling for non-negotiated cases

Add missing unlock when returning
not negotiated status in glbasesrc.

Part-of: <https://gitlab.freedesktop.org/gstreamer/gstreamer/-/merge_requests/10142>
---
 gst-libs/gst/gl/gstglbasesrc.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/gst-libs/gst/gl/gstglbasesrc.c b/gst-libs/gst/gl/gstglbasesrc.c
index 86cd9d4..75e7db9 100644
--- a/gst-libs/gst/gl/gstglbasesrc.c
+++ b/gst-libs/gst/gl/gstglbasesrc.c
@@ -405,6 +405,7 @@ gst_gl_base_src_fill (GstPushSrc * psrc, GstBuffer * buffer)
 
   if (!gst_video_frame_map (&out_frame, &src->out_info, buffer,
           GST_MAP_WRITE | GST_MAP_GL)) {
+    g_rec_mutex_unlock (&src->priv->context_lock);
     return GST_FLOW_NOT_NEGOTIATED;
   }
 
