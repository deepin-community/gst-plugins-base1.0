From: JihoonLee <ejihoon.lee@lge.com>
Date: Wed, 5 Nov 2025 13:56:18 +0900
Subject: encoding-target: Fix memory leak in gst_encoding_target_save

Part-of: <https://gitlab.freedesktop.org/gstreamer/gstreamer/-/merge_requests/10022>
---
 gst-libs/gst/pbutils/encoding-target.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gst-libs/gst/pbutils/encoding-target.c b/gst-libs/gst/pbutils/encoding-target.c
index 3e5dbb2..3c52e0b 100644
--- a/gst-libs/gst/pbutils/encoding-target.c
+++ b/gst-libs/gst/pbutils/encoding-target.c
@@ -1111,7 +1111,8 @@ gst_encoding_target_save (GstEncodingTarget * target, GError ** error)
   if (g_mkdir_with_parents (dirname, 0755)) {
     GST_ERROR_OBJECT (target, "Could not create directory to save %s into: %s",
         target->name, g_strerror (errno));
-
+    g_free (dirname);
+    g_free (lfilename);
     return FALSE;
   }
   filename = g_build_filename (dirname, lfilename, NULL);
